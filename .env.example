# Config do Hub — copie para `.env` (o .env real fica FORA do git, só na VM).
#   cp .env.example .env   &&   edite os valores
# O docker-compose lê este .env automaticamente.

# Porta publicada na VM (default 8000). No ambiente atual a 80 está ocupada pelo
# Conciliador, então o Hub sobe na 8001.
HOST_PORT=8001

# Segredo do JWT. Em prod é OBRIGATÓRIO trocar (o startup falha com o default
# quando SUPERFRIO_ENV=prod). Gere um forte:  openssl rand -hex 32
SUPERFRIO_JWT_SECRET=troque-por-uma-string-aleatoria-forte
SUPERFRIO_ENV=prod

# --- Postgres (Lote 2) ---
# Credenciais do container `db`. Em prod, defina uma senha forte aqui.
POSTGRES_USER=hub
POSTGRES_PASSWORD=troque-por-uma-senha-forte
POSTGRES_DB=hub

# Connection string que o Hub usa. Aponta pro service `db` do compose.
# A senha aqui tem que bater com POSTGRES_PASSWORD acima.
# Para ROLLBACK pro SQLite: comente esta linha (cai no volume ./data).
DATABASE_URL=postgresql+psycopg://hub:troque-por-uma-senha-forte@db:5432/hub
